{
  "name": "focal-rps",
  "version": "1.0.0",
  "private": true,
  "description": "FOCAL Resource Planning System — centralized, multi-user resource forecasting for an MEP engineering consultancy.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/web",
    "build": "npm run build --workspace apps/web",
    "preview": "npm run preview --workspace apps/web",
    "test": "npm run test --workspace packages/engine",
    "test:engine": "npm run test --workspace packages/engine",
    "typecheck": "npm run typecheck --workspace apps/web"
  },
  "engines": {
    "node": ">=18"
  }
}
